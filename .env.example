# MongoDB Atlas connection string
# Example:
# mongodb+srv://<username>:<password>@<cluster-url>/?retryWrites=true&w=majority&appName=<app-name>
MONGODB_ATLAS_URI=

# Notebook defaults
ATLAS_DB_NAME=auto_embedding_lab
ATLAS_COLLECTION_NAME=documents

# Optional: if your Atlas auto-embedding model provider requires an API key.
# Example for Voyage model provider integrations.
VOYAGE_API_KEY=
